<!-- Row start -->
<div class="row">
    <div class="col-lg-12">
        <!-- <h6 class="sub-title">Tab With Icon</h6> -->
         <div class="d-flex justify-content-between sub-title p-3">
             <div class="">Tous les cours</div>
            <a href="add" class="btn btn-primary text-light"><i class="fa fa-plus"></i>Ajouter un cours</a>
         </div>
        
        <!-- Nav tabs -->
        <ul class="nav nav-tabs md-tabs " role="tablist">
            <li class="nav-item">
                <a class="nav-link active" data-toggle="tab" href="#home7" role="tab"><i
                        class="icofont icofont-home"></i>Vidéos</a>
                <div class="slide"></div>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-toggle="tab" href="#profile7" role="tab"><i
                        class="icofont icofont-ui-user "></i>Fichier</a>
                <div class="slide"></div>
            </li>

        </ul>
        <!-- Tab panes -->
        <div class="tab-content card-block">
            <div class="tab-pane active" id="home7" role="tabpanel">
                <!-- Hover table card start -->
                <div class="card">
                    <div class="card-header">
                        <h5>Cours vidéos</h5>
                        <span>Tous les cours vidéos <code>CMS</code></span>
                        <div class="card-header-right">
                            <ul class="list-unstyled card-option">
                                <li><i class="fa fa fa-wrench open-card-option"></i></li>
                                <li><i class="fa fa-window-maximize full-card"></i></li>
                                <li><i class="fa fa-minus minimize-card"></i></li>
                                <li><i class="fa fa-refresh reload-card"></i></li>
                                <li><i class="fa fa-trash close-card"></i></li>
                            </ul>
                        </div>
                    </div>
                    <div class="card-block table-border-style">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="bg-primary">
                                    <tr>
                                        <th>#</th>
                                        <th>Titre</th>
                                        <th>Déscription</th>
                                        <th>Type</th>
                                        <th>Création</th>
                                        <th>Modification</th>
                                        <th>Gérer</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% cours.forEach(v=>{ %>
                                        <tr>
                                            <th scope="row"><%=v.id%></th>
                                            <td><a href="#" role="button" data-toggle="modal" onclick="view('<%=v.video%>')" data-target="#preview"><%=v.titre%></a></td>
                                            <td><%=v.description%></td>
                                            <td>Vidéo/MP4</td>
                                            <td><%=v.createdAt.toLocaleDateString('fr-FR')%></td>
                                            <td><%=v.updatedAt.toLocaleDateString('fr-FR')%></td>
                                            <td>
                                                <a href="" class="btn btn-danger" title="supprimer"><i class="fa fa-trash"></i></a>
                                            </td>
                                        </tr>
                                    <% }) %>

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <!-- Hover table card end -->
            </div>
            <div class="tab-pane" id="profile7" role="tabpanel">
                <!-- Hover table card start -->
                <div class="card">
                    <div class="card-header">
                        <h5>Document</h5>
                        <span>Tous les document <code>CMS</code></span>
                        <div class="card-header-right">
                            <ul class="list-unstyled card-option">
                                <li><i class="fa fa fa-wrench open-card-option"></i></li>
                                <li><i class="fa fa-window-maximize full-card"></i></li>
                                <li><i class="fa fa-minus minimize-card"></i></li>
                                <li><i class="fa fa-refresh reload-card"></i></li>
                                <li><i class="fa fa-trash close-card"></i></li>
                            </ul>
                        </div>
                    </div>
                    <div class="card-block table-border-style">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="bg-primary">
                                    <tr>
                                        <th>#</th>
                                        <th>Titre</th>
                                        <th>Déscription</th>
                                        <th>Type</th>
                                        <th>Création</th>
                                        <th>Modification</th>
                                        <th>Gérer</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <th scope="row">1</th>
                                        <td>Titre</td>
                                        <td>Déscription</td>
                                        <td>Type</td>
                                        <td>Création</td>
                                        <td>Modification</td>
                                        <td>Gérer</td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <!-- Hover table card end -->
            </div>

        </div>
    </div>

</div>
<!-- Row end -->

<div class="modal fade" id="preview">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-end">
                <button id="fermer" class="btn-close btn btn-danger" data-dismiss="modal"><i class="fa fa-close bg-danger text-light"></i></button>
            </div>
            <div class="modal-body">
                <video src="" class="img-fluid" controls></video>
            </div>
        </div>
    </div>
</div>

<script>
    function view(src){
        document.querySelector('video').src = 'assets/videos/'+src;
        const video= document.querySelector('video');
        $("#fermer").click(function(){
            video.pause();
           video.currentTime=0;
        })
    }
</script>