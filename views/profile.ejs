<h2 class="font-bold text-xl mb-4">Profil</h2>

<img id="avatar" src="<%= user.avatar %>" class="w-20 rounded-full">

<p class="mt-2"><%= user.name %></p>
<p>Niveau <%= user.level %> • <%= user.xp %> XP</p>

<input type="file" onchange="changeAvatar(event)" class="mt-3">

<div class="mt-4 grid grid-cols-3 text-center">
  <div><b>12</b><p>Cours</p></div>
  <div><b>8</b><p>Certificats</p></div>
  <div><b>24h</b><p>Temps</p></div>
</div>